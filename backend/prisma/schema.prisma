generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String         @id @default(uuid(7))
  username         String         @unique
  email            String?        @unique
  email_unverified String?        @unique
  password         String
  desc             String?        @db.VarChar(200)
  avatar           Bytes?
  rank             Ranks          @default(PENDING)
  date             DateTime       @default(now())
  verifyToken      String?        @unique
  verifyTimeout    DateTime?
  refreshToken     String?        @unique
  refreshTimeout   DateTime?
  sentRequests     Friend[]       @relation("requester")
  receivedRequests Friend[]       @relation("addressee")
  blocked          Block[]        @relation("blocker")
  blockedBy        Block[]        @relation("blocked")
  dmChatUserA      DMChat[]       @relation("userA")
  dmChatUserB      DMChat[]       @relation("userB")
  dMSender         DMMessage[]    @relation("sender")
  lobbyMessages    LobbyMessage[] @relation("sender")
  lobbyBan         LobbyBan[]     @relation("user")
}

enum Ranks {
  PENDING
  USER
  MODERATOR
  ADMIN
}

model Friend {
  requester   User         @relation("requester", fields: [requesterId], references: [id], onDelete: Cascade)
  requesterId String
  addressee   User         @relation("addressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  addresseeId String
  status      FriendStatus @default(PENDING)
  created     DateTime     @default(now())

  @@id([requesterId, addresseeId])
  @@index([addresseeId])
}

enum FriendStatus {
  PENDING
  ACCEPTED
}

model Block {
  blocker   User     @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockerId String
  blocked   User     @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  blockedId String
  created   DateTime @default(now())

  @@id([blockerId, blockedId])
  @@index([blockedId])
}

model DMChat {
  userA    User        @relation("userA", fields: [userAId], references: [id], onDelete: Cascade)
  userAId  String
  userB    User        @relation("userB", fields: [userBId], references: [id], onDelete: Cascade)
  userBId  String
  messages DMMessage[] @relation("chat")
  id       String      @id @default(uuid(7))

  @@unique([userAId, userBId])
  @@index([userBId])
}

model DMMessage {
  id       String @id @default(uuid(7))
  chat     DMChat @relation("chat", fields: [chatId], references: [id], onDelete: Cascade)
  chatId   String
  message  String @db.VarChar(500)
  sender   User   @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)
  senderId String

  @@index([chatId])
}

model LobbyMessage {
  id        String  @id @default(uuid(7))
  sender    User?   @relation("sender", fields: [senderId], references: [id], onDelete: SetNull)
  senderId  String?
  message   String  @db.VarChar(500)
  moderated Boolean @default(false)
}

model LobbyBan {
  user   User     @relation("user", fields: [userId], references: [id], onDelete: Cascade)
  userId String   @id
  date   DateTime @default(now())
}
