generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String     @id @default(uuid(7))
  username         String     @unique
  email            String?    @unique
  email_unverified String?    @unique
  password         String
  desc             String?    @db.VarChar(200)
  avatar           Bytes?
  rank             Ranks      @default(PENDING)
  date             DateTime   @default(now())
  verifyToken      String?    @unique
  verifyTimeout    DateTime?
  refreshToken     String?    @unique
  refreshTimeout   DateTime?
  sentRequests     Friend[]   @relation("requester")
  receivedRequests Friend[]   @relation("addressee")
  blocked          Block[]    @relation("blocker")
  blockedBy        Block[]    @relation("blocked")
  chatUserA        Chat[]     @relation("userA")
  chatUserB        Chat[]     @relation("userB")
  messageSender    Message[]  @relation("sender")
}

enum Ranks {
  PENDING
  USER
  MODERATOR
  ADMIN
}

model Friend {
  requester   User         @relation("requester", fields: [requesterId], references: [id], onDelete: Cascade)
  requesterId String
  addressee   User         @relation("addressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  addresseeId String
  status      FriendStatus @default(PENDING)
  created     DateTime     @default(now())

  @@id([requesterId, addresseeId])
  @@index([addresseeId])
}

enum FriendStatus {
  PENDING
  ACCEPTED
}

model Block {
  blocker   User     @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockerId String
  blocked   User     @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  blockedId String
  created   DateTime @default(now())

  @@id([blockerId, blockedId])
  @@index([blockedId])
}

model Chat {
  userA     User      @relation("userA", fields: [userAId], references: [id], onDelete: Cascade)
  userAId   String
  userB     User      @relation("userB", fields: [userBId], references: [id], onDelete: Cascade)
  userBId   String
  messages  Message[] @relation("chat")
  id        String    @id @default(uuid(7))

  @@unique([userAId, userBId])
  @@index([userBId])
}

model Message {
  id        String  @id @default(uuid(7))
  chat      Chat    @relation("chat", fields: [chatId], references: [id], onDelete: Cascade)
  chatId    String
  message   String  @db.VarChar(500)
  sender    User    @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)
  senderId  String
}