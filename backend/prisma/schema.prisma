generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String    @id @default(uuid(7))
  username         String    @unique
  email            String?   @unique
  email_unverified String?   @unique
  password         String
  desc             String?   @db.VarChar(200)
  avatar           String?
  rank             Role      @default(USER)
  date             DateTime  @default(now())
  sentRequests     Friends[] @relation("requester")
  receivedRequests Friends[] @relation("addressee")
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

model Friends {
  requester   User         @relation("requester", fields: [requesterId], references: [id], onDelete: Cascade)
  requesterId String
  addressee   User         @relation("addressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  addresseeId String
  status      FriendStatus @default(PENDING)
  created     DateTime     @default(now())

  @@id([requesterId, addresseeId])
  @@index([addresseeId]) // Index for addresseId only, requesterId is covered by the id index
}

enum FriendStatus {
  PENDING
  ACCEPTED
  BLOCKED
}
